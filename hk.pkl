amends "package://github.com/jdx/hk/releases/download/v1.53.0/hk@1.53.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.53.0/hk@1.53.0#/Builtins.pkl"
import "package://github.com/hugoh/hk-config/releases/download/v1.2.1/hk-config@1.2.1#/base.pkl" as Base

min_hk_version = Base.min_hk_version

local linters = new Mapping<String, Step> {
    ...Base.base
    ...Base.python
}

hooks {
    ["pre-commit"]  { fix = true; stash = "git"; steps = linters }
    ["pre-push"]    { steps = linters }
    ["check"]       { steps = linters }
    ["fix"]         { fix = true; steps = linters }
    ["commit-msg"]  { steps = new Mapping<String, Step> { ...Base.commit_msg } }
}
